rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /settings/global {
      allow read: if true;
      allow update: if request.auth != null && (request.auth.token.email in resource.data.admins || resource.data.admins.size() == 0) && request.resource.data.keys().size() > 0;
      allow create: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email in get(/databases/$(database)/documents/settings/global).data.admins || get(/databases/$(database)/documents/settings/global).data.admins.size() == 0);
    }
  }
}
